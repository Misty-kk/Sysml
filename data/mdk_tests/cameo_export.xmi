<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:xmi="http://www.omg.org/spec/XMI/20131001"
         xmlns:uml="http://www.omg.org/spec/UML/20131001"
         xmlns:sysml="http://www.omg.org/spec/SysML/20181001">
  <uml:Model xmi:id="MODEL-MDK-XMI" name="MDK XMI Cameo Export Test">
    <packagedElement xmi:type="uml:Class"
                     xmi:id="REQ-MDK-XMI-001"
                     name="XMI exported energy margin requirement"
                     stereotype="requirement">
      <ownedComment body="Imported through XMI / Cameo Export."/>
      <taggedValue name="text" value="Battery SOC shall remain above 30 percent during worst-case eclipse."/>
      <taggedValue name="verification" value="Simulation"/>
      <taggedValue name="owner" value="MDK Test"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class"
                     xmi:id="BLK-MDK-XMI-BATTERY"
                     name="XMI exported battery block"
                     stereotype="block">
      <taggedValue name="capacity" value="80 Ah"/>
      <taggedValue name="owner" value="MDK Test"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Class"
                     xmi:id="TST-MDK-XMI-001"
                     name="XMI exported energy simulation"
                     stereotype="testCase">
      <taggedValue name="method" value="Cameo-exported simulation placeholder"/>
      <taggedValue name="criterion" value="SOC_min >= 30%"/>
      <taggedValue name="owner" value="MDK Test"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Dependency"
                     xmi:id="REL-MDK-XMI-001"
                     name="satisfy"
                     client="REQ-MDK-XMI-001"
                     supplier="BLK-MDK-XMI-BATTERY"
                     sysmlRelation="satisfy"/>
    <packagedElement xmi:type="uml:Dependency"
                     xmi:id="REL-MDK-XMI-002"
                     name="verify"
                     client="REQ-MDK-XMI-001"
                     supplier="TST-MDK-XMI-001"
                     sysmlRelation="verify"/>
  </uml:Model>
  <sysml:Requirement base_Class="REQ-MDK-XMI-001"/>
  <sysml:Block base_Class="BLK-MDK-XMI-BATTERY"/>
  <sysml:TestCase base_Class="TST-MDK-XMI-001"/>
</xmi:XMI>
